# Copy this file to ".env" and fill in the values.

# --- Sessions (required) -------------------------------------------------
# Any long random string. Generate one with:  python -c "import secrets;print(secrets.token_hex(32))"
SESSION_SECRET=change-me-to-a-long-random-string

# --- Google sign-in ------------------------------------------------------
# Create an OAuth 2.0 Client ID (type: Web application) at:
#   https://console.cloud.google.com/apis/credentials
# Add an authorized redirect URI:
#   local:  http://localhost:8000/auth/callback
#   hosted: https://YOUR_DOMAIN/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: force the redirect URI (otherwise inferred from the request).
# OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback

# Local shortcut: set to 1 to SKIP Google sign-in entirely (single local user).
# Handy for your friend to run it without creating Google credentials.
AUTH_DISABLED=0

# Set to 1 when served over HTTPS in production (secure session cookie).
HTTPS_ONLY=0

# --- Anthropic API key ---------------------------------------------------
# Optional. Each signed-in user can paste their OWN key in the app UI.
# If you set a key here, it's used as a fallback for users who haven't added one.
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# Optional model overrides (defaults shown)
REVIEWER_MODEL=claude-sonnet-4-6
SYNTH_MODEL=claude-sonnet-4-6

# --- Corporate proxy (optional) ------------------------------------------
# Standard HTTPS_PROXY/HTTP_PROXY are honored automatically. Set these only if
# you're behind a proxy that needs extra handling:
# ANTHROPIC_PROXY=http://proxy.company.com:8080      # explicit proxy URL
# ANTHROPIC_CA_BUNDLE=/path/to/corporate-root-ca.pem # for TLS-inspecting proxies (preferred)
# ANTHROPIC_SKIP_TLS_VERIFY=0   # set to 1 only as a last resort (INSECURE)
